# AI要約バッチ（scripts/summarize.ts）で使用する Anthropic API キー
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 既定の要約モデル（コスト最適・キャッシュ前提）
SUMMARY_MODEL=claude-haiku-4-5

# スクレイピング時の User-Agent に埋め込む連絡先（規約遵守・問い合わせ先の明示）
SCRAPER_CONTACT_EMAIL=contact@example.com

# 本番サイトのURL（sitemap.xml / robots.txt / metadataBase に使用）
NEXT_PUBLIC_SITE_URL=https://aichi-seiji-map.vercel.app

# ──────────────────────────────────────────────────────────────
# SNS自動投稿（scripts/buffer_post.py・Buffer API経由でX/Threadsに投稿）
# ──────────────────────────────────────────────────────────────
# Buffer の新GraphQL API（https://api.buffer.com）のパーソナルAPIキー。
# 取得: Buffer にログイン → 組織オーナーで「パーソナルAPIキー」を発行。
# このキーは秘密情報。.env（gitignore済み）にのみ記入し、チャットや公開リポジトリに貼らないこと。
BUFFER_API_KEY=your_buffer_personal_api_key_here

# 任意: 投稿先チャンネルIDを限定したい場合に指定（カンマ区切り）。
# 空なら verify で確認した「政治のトリセツ」のX/Threadsチャンネルを使う。
BUFFER_CHANNEL_IDS=
